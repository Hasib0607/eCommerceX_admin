APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Local HTTP: false + lax. HTTPS React on another host: SESSION_SECURE_COOKIE=true, SESSION_SAME_SITE=none
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis

{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/mehediishere/pathao-courier.git"
        }
    ],
    "require": {
        "php": "^8.0.2",
        "barryvdh/laravel-dompdf": "^2.0",
        "brian2694/laravel-toastr": "^5.57",
        "codeboxr/ecourier-courier": "^1.0",
        "codeboxr/pathao-courier": "dev-main",
        "codeboxr/redx-courier": "^1.0",
        "domainreseller/php-dna": "^3.0",
        "elic-dev/laravel-math-captcha": "^1.1",
        "facebook/graph-sdk": "^5.1",
        "guzzlehttp/guzzle": "^7.2",
        "hardevine/shoppingcart": "^3.1",
        "intervention/image": "^2.7",
        "jenssegers/agent": "^2.6",
        "karim007/laravel-bkash-tokenize": "^2.3",
        "karim007/laravel-nagad": "^1.2",
        "laravel/framework": "^9.2",
        "laravel/octane": "^1.3",
        "laravel/sanctum": "^2.14.1",
        "laravel/socialite": "^5.6",
        "laravel/tinker": "^2.7",
        "laravel/ui": "^4.0",
        "maatwebsite/excel": "^3.1",
        "milon/barcode": "^9.0",
        "pear/text_languagedetect": "^1.0",
        "predis/predis": "^3.0",
        "programmertowheed/bd-courier-fraud-checker": "^1.0",
        "propaganistas/laravel-phone": "^5.1",
        "pusher/pusher-php-server": "^7.0",
        "rosell-dk/webp-convert": "^2.9",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "srmklive/paypal": "~3.0",
        "steadfast-courier/steadfast-courier-laravel-package": "^1.1",
        "stevebauman/location": "^6.6",
        "stripe/stripe-php": "^15.6",
        "symfony/browser-kit": "^7.2",
        "symfony/css-selector": "^7.2",
        "symfony/dom-crawler": "^7.2",
        "symfony/http-client": "^7.2",
        "twilio/sdk": "^8.3",
        "tymon/jwt-auth": "*",
        "unisharp/laravel-filemanager": "^2.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/breeze": "^1.8",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.5.10",
        "spatie/laravel-ignition": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/Others.php",
            "app/Helpers/SmsHelper.php",
            "app/Helpers/ModulusHelper.php",
            "app/Helpers/CheckClientSms.php",
            "app/Helpers/Functions.php",
            "app/Helpers/Countries.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "karim007/laravel-bkash-tokenize",
                "karim007/laravel-nagad",
                "spatie/laravel-ignition",
                "unisharp/laravel-filemanager"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
